<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="quickdock-v3.exe"
        Arguments=""
        InstallLocation="C:\Program Files\My Company\快启坞">
    </Installer>
    <PackageInformation
        PackageName="快启坞"
        PackageDisplayName="快启坞"
        PublisherName="CN=My Company"
        PublisherDisplayName="My Company"
        Version="0.1.0.0"
        PackageDescription="快启坞 QuickDock — 开发者资源集合与快速启动工具">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="com.quickdock.app"
                Description="快启坞 QuickDock — 开发者资源集合与快速启动工具"
                DisplayName="快启坞"
                ExecutableName="quickdock-v3.exe"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>快启坞</DisplayName>
            <PublisherDisplayName>My Company</PublisherDisplayName>
            <Description>快启坞 QuickDock — 开发者资源集合与快速启动工具</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="quickdock-v3.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
