{
  "id": "com.quickdock.base64",
  "name": "Base64 编码解码",
  "version": "1.0.0",
  "description": "Base64 编码 / 解码工具，支持文本和文件",
  "author": "QuickDock",
  "icon": "icon.svg",
  "category": "开发工具",

  "backend": {
    "runtime": "python",
    "entry": "main.py",
    "args": []
  },

  "frontend": {
    "enabled": true,
    "entry": "frontend/index.html",
    "width": 500,
    "height": 400
  },

  "capabilities": ["command"],

  "permissions": {
    "network": false,
    "filesystem": false,
    "clipboard": true
  },

  "commands": [
    {
      "id": "encode",
      "title": "Base64 编码：选中文本",
      "hotkey": ""
    },
    {
      "id": "decode",
      "title": "Base64 解码：选中文本",
      "hotkey": ""
    }
  ]
}
