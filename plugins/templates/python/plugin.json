{
  "id": "com.quickdock.my-python-plugin",
  "name": "Python 插件示例",
  "version": "1.0.0",
  "description": "使用 Python 开发的 QuickDock 插件",
  "author": "Your Name",

  "backend": {
    "runtime": "python",
    "entry": "main.py",
    "args": []
  },

  "frontend": {
    "enabled": false
  },

  "capabilities": ["command"],

  "permissions": {
    "network": false,
    "filesystem": false,
    "clipboard": true
  },

  "commands": [
    {
      "id": "hello",
      "title": "Hello World",
      "hotkey": ""
    }
  ]
}
