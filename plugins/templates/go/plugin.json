{
  "id": "com.quickdock.my-go-plugin",
  "name": "Go 插件示例",
  "version": "1.0.0",
  "description": "使用 Go 语言开发的 QuickDock 插件",
  "author": "Your Name",
  "icon": "",

  "backend": {
    "runtime": "native",
    "entry": "main.exe",
    "args": []
  },

  "frontend": {
    "enabled": false
  },

  "capabilities": [
    "command"
  ],

  "permissions": {
    "network": false,
    "filesystem": false,
    "clipboard": true
  },

  "commands": [
    {
      "id": "hello",
      "title": "Hello World",
      "hotkey": ""
    }
  ]
}
